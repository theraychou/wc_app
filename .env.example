# ----------------------------------------------------------------------------
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local. Only NEXT_PUBLIC_* vars are exposed to the browser.
# ----------------------------------------------------------------------------

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses Row-Level Security. Used ONLY by /api/sync and admin
# server actions. Must never be imported into client components.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- API-Football (api-sports.io -> Dashboard -> API Key) ---
# World Cup 2026 is league=1, season=2026. Free tier = 100 requests/day.
APISPORTS_KEY=your-api-football-key

# Which competition/season the sync pulls. The free plan only covers seasons
# 2022-2024, so for development point this at the real 2022 World Cup. Use
# season=2026 for the live pool (requires a plan that can access it).
WC_LEAGUE_ID=1
WC_SEASON=2026

# --- Sync protection ---
# Long random string. /api/sync rejects any request without it.
# Generate one with:  openssl rand -hex 32
SYNC_SECRET=replace-with-a-long-random-string

# --- App ---
# Used for the magic-link email redirect. No trailing slash.
# Local dev: http://localhost:3000   Production: your Vercel URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
